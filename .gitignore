# --- Rust ---
/target
/target-musl-*

# --- Node (web frontend) ---
# Build artifacts stay out of the repo: run `npm ci && npm run build` in
# crates/pg_lens_web/frontend before building with the `web` feature
# (build.rs fails with instructions if dist/ is missing).
node_modules/
crates/pg_lens_web/frontend/dist/

# --- Python tooling (e2e harnesses) ---
__pycache__/
*.pyc

# --- OS junk ---
.DS_Store

# --- Editors / local AI tooling ---
.vscode/
.idea/
.claude/
.remember/

# --- Secrets & local config: never commit ---
.env
.env.*
*.pem
*.key
/services.toml

# --- Logs & scratch ---
*.log
*.tmp
